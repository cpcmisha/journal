{
    "name": "cpcmisha/journalnotes",
    "description": "A Markdown journal and personal knowledge workspace for Nextcloud.",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Miguel Torres",
            "email": "miguel@misha.pe",
            "homepage": "https://miguel.pe/"
        }
    ],
    "config": {
        "platform": {
            "php": "8.2"
        },
        "autoloader-suffix": "JournalNotes",
